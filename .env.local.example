# ============================================================
# VelgTakst – Miljøvariabler
# Kopier denne filen til .env.local og fyll inn verdiene
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://din-prosjekt-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=din-anon-key
SUPABASE_SERVICE_ROLE_KEY=din-service-role-key

# App URL (brukes til OAuth-callbacks)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================================
# Google Calendar OAuth2
# Opprett credentials på: https://console.cloud.google.com/
# 1. Opprett et nytt prosjekt (eller bruk eksisterende)
# 2. Aktiver "Google Calendar API" under APIs & Services
# 3. Gå til "Credentials" → "Create Credentials" → "OAuth client ID"
# 4. Velg "Web application"
# 5. Legg til Authorized redirect URI:
#    - Lokalt: http://localhost:3000/api/auth/google/callback
#    - Produksjon: https://ditt-domene.no/api/auth/google/callback
# ============================================================
GOOGLE_CLIENT_ID=din-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=din-google-client-secret

# Vipps
# VIPPS_CLIENT_ID=                        # Login-MSN nøkler
# VIPPS_CLIENT_SECRET=
# VIPPS_SUBSCRIPTION_KEY=
# VIPPS_MSN=                              # Login-MSN (innlogging)
# VIPPS_RECURRING_MSN=                    # Recurring-MSN (abonnement)
# VIPPS_RECURRING_CLIENT_ID=              # Recurring-MSN nøkler
# VIPPS_RECURRING_CLIENT_SECRET=
# VIPPS_RECURRING_SUBSCRIPTION_KEY=
# VIPPS_RECURRING_WEBHOOK_SECRET=
# VIPPS_TEST_MODE=true

# E-post
# EMAIL_FROM=noreply@velgtakst.no
